pipeline {
    agent {
        label 'slave'
    }
    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['qa', 'dev', 'prod'],
            description: 'Select the environment to deploy'
        )
    }

    stages {
        stage('Hostanme') {
            steps {
                sh 'hostname'
            }
        }
        stage('Present working directory') {
            steps {
                sh 'pwd'
            }
        }
        stage('display the mounted path') {
            steps {
                sh 'df -h'
            }
        }
    }
}
